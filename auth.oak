// luna-api/auth provides authentication primitives for the Luna/Privy SDK.
//
// Wraps login, logout, MFA, and account management flows into idiomatic Oak
// interfaces. When compiled to --target web, calls resolve to the underlying
// Privy React hooks; in other targets they operate through the HTTP bridge.

{
	default: default
	map: map
	each: each
	entries: entries
} := import('std')
json := import('json')

// --- Configuration -----------------------------------------------------------

// _cfg holds module-level auth configuration. Set via configure().
_cfg := {
	appId: ''
	apiBase: 'https://lunaapi-production.up.railway.app/api'
	privyBase: 'https://auth.privy.io'
	clientId: ''
	token: ?
	refreshToken: ?
}

// configure sets auth module config.
//  configure({ appId: 'clx...', apiBase: 'https://...' })
fn configure(opts) {
	_cfg.appId <- default(opts.appId, _cfg.appId)
	_cfg.apiBase <- default(opts.apiBase, _cfg.apiBase)
	_cfg.privyBase <- default(opts.privyBase, _cfg.privyBase)
	_cfg.clientId <- default(opts.clientId, _cfg.clientId)
}

// --- Token state -------------------------------------------------------------

fn getToken() _cfg.token
fn setToken(t) _cfg.token <- t
fn getRefreshToken() _cfg.refreshToken
fn setRefreshToken(t) _cfg.refreshToken <- t

fn authenticated?() _cfg.token != ?

// _authHeaders builds standard auth headers for Privy API calls.
fn _authHeaders() {
	h := { 'Content-Type': 'application/json' }
	if _cfg.appId != '' -> h.'privy-app-id' <- _cfg.appId
	if _cfg.clientId != '' -> h.'privy-client-id' <- _cfg.clientId
	if _cfg.token != ? -> h.'Authorization' <- 'Bearer ' + string(_cfg.token)
	h
}

// --- Login Methods -----------------------------------------------------------

fn loginWithEmail(email) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/passwordless/init', json.serialize({ email: email }))
	_parseAuthResponse(resp)
}

fn verifyEmailCode(flowId, code) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/passwordless/authenticate', json.serialize({ flowId: flowId, code: code }))
	result := _parseAuthResponse(resp)
	if result.token != ? -> {
		setToken(result.token)
		setRefreshToken(result.refreshToken)
	}
	result
}

fn loginWithOAuth(provider, opts) {
	body := json.serialize({ provider: string(provider), redirectUrl: default(opts.redirectUrl, '') })
	resp := _req('POST', _cfg.privyBase + '/api/v1/oauth/init', body)
	_parseAuthResponse(resp)
}

fn loginWithSms(phone) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/passwordless_sms/init', json.serialize({ phone: phone }))
	_parseAuthResponse(resp)
}

fn verifySmsCode(flowId, code) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/passwordless_sms/authenticate', json.serialize({ flowId: flowId, code: code }))
	result := _parseAuthResponse(resp)
	if result.token != ? -> {
		setToken(result.token)
		setRefreshToken(result.refreshToken)
	}
	result
}

fn loginWithPasskey(opts) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/passkeys/authenticate/init', json.serialize(default(opts, {})))
	_parseAuthResponse(resp)
}

fn signupWithPasskey(opts) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/passkeys/register', json.serialize(default(opts, {})))
	result := _parseAuthResponse(resp)
	if result.token != ? -> {
		setToken(result.token)
		setRefreshToken(result.refreshToken)
	}
	result
}

fn loginWithSiwe(message, signature) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/siwe/authenticate', json.serialize({ message: message, signature: signature }))
	result := _parseAuthResponse(resp)
	if result.token != ? -> {
		setToken(result.token)
		setRefreshToken(result.refreshToken)
	}
	result
}

// initSiwe requests a SIWE challenge nonce/message to sign.
fn initSiwe(opts) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/siwe/init', json.serialize(default(opts, {})))
	_parseAuthResponse(resp)
}

fn loginWithTelegram(telegramAuthData) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/telegram/authenticate', json.serialize({ telegramAuthData: telegramAuthData }))
	result := _parseAuthResponse(resp)
	if result.token != ? -> {
		setToken(result.token)
		setRefreshToken(result.refreshToken)
	}
	result
}

// linkTelegram links a Telegram account to the authenticated user.
fn linkTelegram(telegramAuthData) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/telegram/link', json.serialize({ telegramAuthData: telegramAuthData }))
	_parseAuthResponse(resp)
}

// unlinkTelegram unlinks the Telegram account.
fn unlinkTelegram() {
	resp := _req('POST', _cfg.privyBase + '/api/v1/telegram/unlink', json.serialize({}))
	_parseAuthResponse(resp)
}

fn loginWithCustomAuth(customToken) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/custom_jwt_account/authenticate', json.serialize({ token: customToken }))
	result := _parseAuthResponse(resp)
	if result.token != ? -> {
		setToken(result.token)
		setRefreshToken(result.refreshToken)
	}
	result
}

fn loginWithSiws(message, signature) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/siws/authenticate', json.serialize({ message: message, signature: signature }))
	result := _parseAuthResponse(resp)
	if result.token != ? -> {
		setToken(result.token)
		setRefreshToken(result.refreshToken)
	}
	result
}

// initSiws requests a SIWS (Sign-In With Solana) challenge.
fn initSiws(opts) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/siws/init', json.serialize(default(opts, {})))
	_parseAuthResponse(resp)
}

fn loginWithFarcaster(opts) {
	resp := _req('POST', _cfg.privyBase + '/api/v2/farcaster/init', json.serialize(default(opts, {})))
	_parseAuthResponse(resp)
}

fn loginAsGuest() {
	resp := _req('POST', _cfg.privyBase + '/api/v1/guest/authenticate', json.serialize({}))
	result := _parseAuthResponse(resp)
	if result.token != ? -> {
		setToken(result.token)
		setRefreshToken(result.refreshToken)
	}
	result
}

fn logout() {
	_req('POST', _cfg.privyBase + '/api/v1/sessions/revoke', json.serialize({}))
	setToken(?)
	setRefreshToken(?)
	{ ok: true }
}

