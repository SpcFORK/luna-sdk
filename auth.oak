	resp := _req('POST', _cfg.privyBase + '/api/v1/siws/link', json.serialize({ message: message, signature: signature }))
	_parseAuthResponse(resp)
}

fn unlinkSiws(address) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/siws/unlink', json.serialize({ address: address }))
