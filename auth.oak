// --- User Info ---------------------------------------------------------------

fn getUser() {
	resp := _req('GET', _cfg.privyBase + '/api/v1/users/me', ?)
	_parseAuthResponse(resp)
}

fn updateAccount(fields) {
	resp := _req('PUT', _cfg.privyBase + '/api/v1/users/me', json.serialize(fields))
	_parseAuthResponse(resp)
}

fn getApp() {
	resp := _req('GET', _cfg.privyBase + '/api/v1/apps/' + _cfg.appId, ?)
	_parseAuthResponse(resp)
}

fn acceptTerms() {
	resp := _req('POST', _cfg.privyBase + '/api/v1/users/me/accept_terms', json.serialize({}))
	_parseAuthResponse(resp)
}

// --- Token Management --------------------------------------------------------

fn getIdentityToken() {
	resp := _req('GET', _cfg.privyBase + '/api/v1/users/me/identity-token', ?)
	_parseAuthResponse(resp)
}

fn getAccessToken() _cfg.token

fn refreshAccessToken() {
	body := json.serialize({ refreshToken: _cfg.refreshToken })
	resp := _req('POST', _cfg.privyBase + '/api/v1/sessions', body)
	result := _parseAuthResponse(resp)
	if result.token != ? -> {
		setToken(result.token)
		setRefreshToken(result.refreshToken)
	}
	result
}

fn getOAuthTokens(provider) {
	resp := _req('GET', _cfg.privyBase + '/api/v1/users/me/oauth/' + string(provider) + '/token', ?)
	_parseAuthResponse(resp)
}

fn getAccessTokenForProvider(provider) {
	resp := _req('GET', _cfg.privyBase + '/api/v1/users/me/access-token/' + string(provider), ?)
	_parseAuthResponse(resp)
}

// --- User Account Updates ----------------------------------------------------

fn updateEmail(email) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/passwordless/update', json.serialize({ email: email }))
	_parseAuthResponse(resp)
}

fn updatePhone(phone) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/passwordless_sms/update', json.serialize({ phone: phone }))
	_parseAuthResponse(resp)
}

// --- MFA SMS -----------------------------------------------------------------

fn mfaInitSms() {
	resp := _req('POST', _cfg.privyBase + '/api/v1/mfa/passwordless_sms/init', json.serialize({}))
	_parseAuthResponse(resp)
}

fn mfaVerifySms(code) {
	resp := _req('POST', _cfg.privyBase + '/api/v1/mfa/passwordless_sms/verify', json.serialize({ code: code }))
	_parseAuthResponse(resp)
}

// --- Internal Helpers --------------------------------------------------------

fn _parseAuthResponse(resp) if resp.status {
	200, 201 -> {
		data := json.parse(resp.body)
		{
			ok: true
			data: data
			token: data.token
			refreshToken: data.refreshToken
			user: data.user
		}
	}
	400, 401, 403, 404, 422 -> {
		data := json.parse(resp.body)
		{
			ok: false
			error: default(data.message, 'Authentication failed')
			code: resp.status
			data: data
		}
	}
	_ -> {
		ok: false
		error: 'Unexpected response: ' + string(resp.status)
		code: resp.status
	}
}

// _req makes an authenticated HTTP request using the builtin req().
// req() is synchronous and returns {type: :resp, resp: {status, headers, body}}.
fn _req(method, url, body) {
	headers := _authHeaders()
	raw := req({
		method: method
		url: url
		headers: headers
		body: default(body, '')
	})
	if raw.type {
		:resp -> raw.resp
		_ -> { status: 0, body: '', headers: {} }
	}
}
