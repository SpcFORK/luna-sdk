// luna-api/delegated provides delegated actions and session signer management
// for the Luna/Privy SDK. Delegated actions allow third-party services to
// perform wallet operations on behalf of users with scoped permissions.

{
	default: default
	map: map
} := import('std')
json := import('json')
auth := import('auth')

// --- Delegated Actions -------------------------------------------------------

fn requestDelegation(address, opts) {
	body := json.serialize({
		address: address
		permissions: default(opts.permissions, [])
		expiresAt: opts.expiresAt
		delegatee: opts.delegatee
	})
	auth._req('POST', auth._cfg.privyBase + '/api/v1/delegated-actions/request', body).then(_parseDelegationResponse)
}

fn approveDelegation(delegationId) {
	auth._req('POST', auth._cfg.privyBase + '/api/v1/delegated-actions/approve', json.serialize({ delegationId: delegationId })).then(_parseDelegationResponse)
}

fn revokeDelegation(delegationId) {
	auth._req('POST', auth._cfg.privyBase + '/api/v1/delegated-actions/revoke', json.serialize({ delegationId: delegationId })).then(_parseDelegationResponse)
}

fn listDelegations() {
	auth._req('GET', auth._cfg.privyBase + '/api/v1/delegated-actions', ?).then(_parseDelegationResponse)
}

// --- Session Signers ---------------------------------------------------------

fn createSessionSigner(opts) {
	body := json.serialize({
		permissions: default(opts.permissions, [:signMessage])
		expiresInSeconds: default(opts.expiresInSeconds, 3600)
		chainIds: opts.chainIds
		walletAddress: opts.walletAddress
	})
	auth._req('POST', auth._cfg.privyBase + '/api/v1/session-signers/create', body).then(_parseSessionResponse)
}

fn revokeSessionSigner(sessionId) {
	auth._req('POST', auth._cfg.privyBase + '/api/v1/session-signers/revoke', json.serialize({ sessionId: sessionId })).then(_parseSessionResponse)
}

fn listSessionSigners() {
	auth._req('GET', auth._cfg.privyBase + '/api/v1/session-signers', ?).then(_parseSessionResponse)
}

// --- Internal ----------------------------------------------------------------

fn _parseDelegationResponse(resp) if resp.status {
	200, 201 -> {
		data := json.parse(resp.body)
		{
			ok: true
			data: data
			delegations: default(data.delegations, [])
		}
	}
	400, 401, 403, 404, 422 -> {
		data := json.parse(resp.body)
		msg := if type(data) {
			:object -> default(data.message, 'Delegation operation failed')
			_ -> 'Delegation operation failed'
		}
		{
			ok: false
			error: msg
			code: resp.status
		}
	}
	_ -> {
		ok: false
		error: 'Unexpected response: ' + string(resp.status)
		code: resp.status
	}
}

fn _parseSessionResponse(resp) if resp.status {
	200, 201 -> {
		data := json.parse(resp.body)
		{
			ok: true
			data: data
			sessions: default(data.sessions, [])
			signer: data.signer
		}
	}
	_ -> _parseDelegationResponse(resp)
}
