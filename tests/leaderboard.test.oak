// leaderboard tests — live leaderboard (no auth)

leaderboard := import('../leaderboard')

fn run(t) {
	leaderboard.get().then(fn(result) {
		'live: leaderboard get responds' |> t.assert(result != ?)
		'live: leaderboard has ok field' |> t.assert(result.ok != ?)
	})

	leaderboard.config().then(fn(cfg) {
		'live: leaderboard config responds' |> t.assert(cfg != ?)
	})
}
