// user tests — featured users (no auth required)

user := import('../user')

fn run(t) {
	// live: featured users
	user.featured({ limit: 5 }).then(fn(result) {
		'live: user featured returns result' |> t.assert(result != ?)
		if result.data != ? -> {
			'live: user featured is list' |> t.assert(type(result.data) = :list)
			if len(result.data) > 0 -> {
				'live: user featured has entries' |> t.assert(true)
				'live: user featured entry has username' |> t.assert(result.data.0.username != ?)
				'live: user featured entry has displayName' |> t.assert(result.data.0.displayName != ?)
			}
		}
	})
}
