// admin tests — structural (admin auth required)

admin := import('../admin')

fn run(t) {
	// admin endpoints require admin token; verify structural response
	admin.triggerPayout().then(fn(result) {
		'admin: triggerPayout returns result' |> t.assert(result != ?)
		'admin: triggerPayout has ok field' |> t.assert(result.ok != ?)
	})
}
