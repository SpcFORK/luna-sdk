// spotlight tests — live active spotlights (no auth)

spotlight := import('../spotlight')

fn run(t) {
	spotlight.active().then(fn(result) {
		'live: spotlight active returns result' |> t.assert(result != ?)
		if result.data != ? -> {
			'live: spotlight active is list' |> t.assert(type(result.data) = :list)
		}
	})
}
