// stats tests — live Luna stats (no auth)

stats := import('../stats')

fn run(t) {
	stats.luna().then(fn(result) {
		'live: stats luna returns result' |> t.assert(result != ?)
		if result.data != ? -> {
			'live: stats has tokenMint' |> t.eq(result.data.tokenMint, '4NBTf8PfLH4oLFnwf3knv46FY9i5oXjDxffCetXRpump')
			'live: stats has totalSwaps' |> t.assert(result.data.totalSwaps >= 0)
			'live: stats has totalLunaBought' |> t.assert(result.data.totalLunaBought >= 0)
		}
	})
}
