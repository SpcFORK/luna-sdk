// solana tests — structural tests for Solana wallet operations

solana := import('../solana')

fn run(t) {
	// createWallet requires auth — verify structured response
	solana.createWallet().then(fn(result) {
		'solana: createWallet returns result' |> t.assert(result != ?)
		'solana: createWallet has ok field' |> t.assert(result.ok != ?)
	})

	// signMessage requires auth
	solana.signMessage('test', { address: '' }).then(fn(signRes) {
		'solana: signMessage returns result' |> t.assert(signRes != ?)
		'solana: signMessage has ok field' |> t.assert(signRes.ok != ?)
	})
}
