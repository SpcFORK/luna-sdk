// search tests — live search (no auth)

search := import('../search')

fn run(t) {
	result := search.search('luna')
	'live: search ok' |> t.eq(result.ok, true)
	'live: search has users list' |> t.assert(type(result.data.users) = :list)
	'live: search has communities list' |> t.assert(type(result.data.communities) = :list)
}
