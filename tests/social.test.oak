// social tests — follow counts (public, no auth)

social := import('../social')

fn run(t) {
	// follow counts for user ID 1 (public endpoint)
	social.followCounts(1).then(fn(result) {
		'live: social followCounts returns result' |> t.assert(result != ?)
		if result.data != ? -> {
			'live: social followCounts has followerCount' |> t.assert(result.data.followerCount >= 0)
			'live: social followCounts has followingCount' |> t.assert(result.data.followingCount >= 0)
		}
	})

	// followers list (public endpoint)
	social.followers(1).then(fn(flist) {
		'live: social followers returns result' |> t.assert(flist != ?)
		if flist.data != ? -> {
			'live: social followers is list' |> t.assert(type(flist.data) = :list)
		}
	})

	// structural: unblock returns result (requires auth)
	social.unblock(1).then(fn(ubRes) {
		'social: unblock returns result' |> t.assert(ubRes != ?)
		'social: unblock has ok field' |> t.assert(ubRes.ok != ?)
	})
}
