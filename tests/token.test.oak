// token tests — live balance & token lists

token := import('../token')

fn run(t) {
	// token info for the Luna token mint
	token.info('4NBTf8PfLH4oLFnwf3knv46FY9i5oXjDxffCetXRpump').then(fn(result) {
		'live: token info responds' |> t.assert(result != ?)
		'live: token info has ok field' |> t.assert(result.ok != ?)
	})

	// dedicated tokens list
	token.dedicated().then(fn(ded) {
		'live: token dedicated responds' |> t.assert(ded != ?)
	})

	// launched tokens list
	token.launched().then(fn(launched) {
		'live: token launched responds' |> t.assert(launched != ?)
	})

	// new exports
	'token.metadata is fn' |> t.eq(type(token.metadata), :function)
	'token.vanityPool is fn' |> t.eq(type(token.vanityPool), :function)

	// live: vanity pool is a public endpoint
	token.vanityPool().then(fn(vp) {
		'live: token vanityPool responds' |> t.assert(vp != ?)
		'live: token vanityPool has ok' |> t.assert(vp.ok != ?)
	})
}
