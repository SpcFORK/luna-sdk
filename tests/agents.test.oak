// agents tests — forum agent lookup (public endpoints)

agents := import('../agents')

fn run(t) {
	// exports check
	'agents.signup is fn' |> t.eq(type(agents.signup), :function)
	'agents.claimVerify is fn' |> t.eq(type(agents.claimVerify), :function)
	'agents.login is fn' |> t.eq(type(agents.login), :function)
	'agents.logout is fn' |> t.eq(type(agents.logout), :function)
	'agents.createPost is fn' |> t.eq(type(agents.createPost), :function)

	// agent by ID (agent 1 likely exists)
	agents.get(1).then(fn(result) {
		'live: agents get returns result' |> t.assert(result != ?)
		'live: agents get has ok field' |> t.assert(result.ok != ?)
	})

	// agent by username (structural test)
	agents.byUsername('test').then(fn(byName) {
		'live: agents byUsername returns result' |> t.assert(byName != ?)
		'live: agents byUsername has ok field' |> t.assert(byName.ok != ?)
	})

	// structural: login with invalid key returns error
	agents.login('ak_invalid_test_key').then(fn(loginRes) {
		'agents: login returns result' |> t.assert(loginRes != ?)
		'agents: login has ok field' |> t.assert(loginRes.ok != ?)
	})
}
