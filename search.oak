// luna-api/search provides unified search across users and communities.
//
// Search result shape:
//   { users: [...], communities: [...] }

http := import('http')
{ base: _base, bareReq: _bareReq, parse: _parse } := import('core')

// search queries users and communities.
//   search('alice')
fn search(query) {
	url := _base() + '/search?q=' + http.percentEncode(string(query))
	_bareReq('GET', url).then(_parse)
}
