// luna-api/donate provides donation/tipping functionality for Luna.
//
// Allows users to send tips/donations to other users or content creators.

json := import('json')
{ base: _base, authReq: _req, parse: _parse } := import('core')

// donate sends a donation/tip.
//   donate({ recipientId: 42, amount: 100, message: 'Great post!' })
fn donate(opts) _req('POST', _base() + '/donate', json.serialize(opts)).then(_parse)
