// SUPPORTED_CHAINS is the registry of all known chains.
SUPPORTED_CHAINS := [
	ethereum, sepolia, holesky
	base, baseSepolia
	polygon, polygonAmoy
	arbitrum, arbitrumSepolia
	optimism, optimismSepolia
	avalanche, avalancheFuji
	bsc
	celo, celoAlfajores
	filecoin
	linea
	zora, zoraSepolia
	immutableZkEvm
	redstone
	unichain
	berachainArtio
	garnetHolesky
	gunzMainnet
	solana, solanaDevnet
]

// --- Chain Lookup ------------------------------------------------------------

// byId returns the chain definition for a given chain ID, or ? if not found.
fn byId(chainId) {
	fn go(i) if i {
		len(SUPPORTED_CHAINS) -> ?
		_ -> if SUPPORTED_CHAINS.(i).id {
			chainId -> SUPPORTED_CHAINS.(i)
			_ -> go(i + 1)
		}
	}
	go(0)
}

// byName returns the chain definition for a given chain name.
fn byName(name) {
	fn go(i) if i {
		len(SUPPORTED_CHAINS) -> ?
		_ -> if SUPPORTED_CHAINS.(i).name {
			name -> SUPPORTED_CHAINS.(i)
			_ -> go(i + 1)
		}
	}
	go(0)
}

// --- RPC Helpers -------------------------------------------------------------

// addRpcOverride returns a new chain object with a Privy RPC URL override.
fn addRpcOverride(chain, rpcUrl) {
	newRpcUrls := chain.rpcUrls
	newRpcUrls.privyWalletOverride <- { http: [rpcUrl] }
	result := chain
	result.rpcUrls <- newRpcUrls
	result
}

// addPrivyRpc adds the default Privy wallet RPC endpoint to a chain.
fn addPrivyRpc(chain) {
	addRpcOverride(chain, 'https://rpc.wallet.coinbase.com')
}

// getRpcUrl retrieves the primary RPC URL for a chain.
fn getRpcUrl(chain) if chain.rpcUrls.privyWalletOverride {
	? -> chain.rpcUrls.default.http.0
	_ -> chain.rpcUrls.privyWalletOverride.http.0
}

// isEvm? returns true if the chain is an EVM chain (numeric ID).
fn isEvm?(chain) type(chain.id) = :int

// isSolana? returns true if the chain is a Solana chain.
fn isSolana?(chain) chain.id = :solana | chain.id = :solanaDevnet

// getExplorerUrl builds a block explorer URL for an address or tx hash.
fn getExplorerUrl(chain, hashOrAddress, kind) {
	baseUrl := chain.blockExplorers.default.url
	prefix := if default(kind, :address) {
		:address -> '/address/'
		:tx -> '/tx/'
		:block -> '/block/'
		_ -> '/address/'
	}
	baseUrl + prefix + string(hashOrAddress)
}
